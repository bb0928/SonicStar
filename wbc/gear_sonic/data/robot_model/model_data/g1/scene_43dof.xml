<mujoco model="g1_43dof scene">
  <include file="g1_29dof_with_hand.xml"/>
  <!-- Note that the hand model in g1_29dof_with_hand.xml is not stable for simulation. -->

  <statistic center="0 0 0.5" extent="2.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="table_mat" rgba="0.50 0.34 0.22 1"/>
    <material name="cup_mat" rgba="0.88 0.92 0.96 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    <!-- Site -->
    <site name="com_marker" pos="0.1 0 0" size="0.05" rgba="1 0 0 1" type="sphere"/>

    <body name="table" pos="0.85 0.00 0.38">
      <geom name="table_top" type="box" size="0.30 0.45 0.02" pos="0 0 0.36" material="table_mat"
        contype="1" conaffinity="1" condim="6" friction="1.2 0.2 0.05"
        solref="0.01 1" solimp="0.95 0.99 0.001"/>
      <geom name="table_leg_fl" type="box" size="0.03 0.03 0.36" pos="0.24 0.38 0.0" material="table_mat"/>
      <geom name="table_leg_fr" type="box" size="0.03 0.03 0.36" pos="0.24 -0.38 0.0" material="table_mat"/>
      <geom name="table_leg_rl" type="box" size="0.03 0.03 0.36" pos="-0.24 0.38 0.0" material="table_mat"/>
      <geom name="table_leg_rr" type="box" size="0.03 0.03 0.36" pos="-0.24 -0.38 0.0" material="table_mat"/>
    </body>

    <body name="cup" pos="0.65 0 0.815">
      <joint name="cup_freejoint" type="free"/>
      <inertial pos="0 0 0" mass="0.12" diaginertia="0.00018 0.00018 0.00010"/>
      <geom name="cup_body" type="cylinder" size="0.025 0.055" material="cup_mat"
        contype="1" conaffinity="1" condim="6" friction="1.5 0.3 0.08"
        solref="0.02 1" solimp="0.9 0.98 0.001"/>
    </body>

    <body name="trash_bin" pos="0.25 -0.65 0.00">
      <geom name="trash_bin_bottom" type="box" size="0.22 0.22 0.02" pos="0 0 0.02"
        rgba="0.16 0.16 0.18 1" contype="1" conaffinity="1" condim="6"
        friction="1.0 0.15 0.03" solref="0.01 1" solimp="0.95 0.99 0.001"/>
      <geom name="trash_bin_wall_front" type="box" size="0.22 0.02 0.28" pos="0 -0.21 0.32"
        rgba="0.18 0.18 0.20 1" contype="1" conaffinity="1" condim="6"
        friction="1.0 0.15 0.03" solref="0.01 1" solimp="0.95 0.99 0.001"/>
      <geom name="trash_bin_wall_back" type="box" size="0.22 0.02 0.28" pos="0 0.21 0.32"
        rgba="0.18 0.18 0.20 1" contype="1" conaffinity="1" condim="6"
        friction="1.0 0.15 0.03" solref="0.01 1" solimp="0.95 0.99 0.001"/>
      <geom name="trash_bin_wall_left" type="box" size="0.02 0.18 0.28" pos="-0.21 0 0.32"
        rgba="0.18 0.18 0.20 1" contype="1" conaffinity="1" condim="6"
        friction="1.0 0.15 0.03" solref="0.01 1" solimp="0.95 0.99 0.001"/>
      <geom name="trash_bin_wall_right" type="box" size="0.02 0.18 0.28" pos="0.21 0 0.32"
        rgba="0.18 0.18 0.20 1" contype="1" conaffinity="1" condim="6"
        friction="1.0 0.15 0.03" solref="0.01 1" solimp="0.95 0.99 0.001"/>
    </body>
  </worldbody>

  <default>
    <geom friction="1.0" condim="6" solref="0.01 1" solimp="0.95 0.99 0.001"/>
  </default>
</mujoco>
